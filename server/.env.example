# SkillForge MiniMax Proxy Server
# Copy this to .env and fill in your values

# Your MiniMax API key (get one at https://platform.minimax.io)
# The server reads this automatically if set.
# Alternatively, the server will try to extract it from ~/.hermes/config.yaml
MINIMAX_API_KEY=sk-cp-your-key-here

# Optional: override the default model
# MODEL=MiniMax-M2.7
